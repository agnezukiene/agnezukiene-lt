{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agnezukienepage",
  "main": "src/index.js",
  "compatibility_date": "2026-07-06",
  "observability": {
    "enabled": true
  },
  "vars": {
    "CONTACT_TO_EMAIL": "zukiene.agne@gmail.com"
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
